<?xml version="1.0"?>
<Container version="2">
  <Name>plex</Name>
  <Repository>linuxserver/plex</Repository>
  <Registry>https://hub.docker.com/r/linuxserver/plex</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <Overview/>
  <Category/>
  <WebUI>http://[IP]:[PORT:32400]/web/</WebUI>
  <TemplateURL/>
  <Icon>https://github.com/plexinc/pms-docker/blob/master/img/plex-server.png?raw=true</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>1585784456</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Description/>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>32400</HostPort>
        <ContainerPort>32400</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/media/tv</HostDir>
      <ContainerDir>/tv</ContainerDir>
      <Mode>ro</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/media/movies/</HostDir>
      <ContainerDir>/movies</ContainerDir>
      <Mode>ro</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/apps/docker/appdata/plex/</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>docker</Value>
      <Name>VERSION</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>1001</Value>
      <Name>PUID</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>100</Value>
      <Name>PGID</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="tv" Target="/tv" Default="" Mode="ro" Description="Container Path: /tv" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/media/tv</Config>
  <Config Name="movies" Target="/movies" Default="" Mode="ro" Description="Container Path: /movies" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/media/movies/</Config>
  <Config Name="VERSION" Target="VERSION" Default="" Mode="" Description="Container Variable: VERSION" Type="Variable" Display="always" Required="false" Mask="false">docker</Config>
  <Config Name="library" Target="/config" Default="" Mode="rw" Description="Container Path: /config" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/apps/docker/appdata/plex/</Config>
  <Config Name="PUID" Target="PUID" Default="" Mode="" Description="Container Variable: PUID" Type="Variable" Display="always" Required="false" Mask="false">1001</Config>
  <Config Name="PGID" Target="PGID" Default="" Mode="" Description="Container Variable: PGID" Type="Variable" Display="always" Required="false" Mask="false">100</Config>
  <Config Name="Remote Access" Target="32400" Default="" Mode="tcp" Description="Container Port: 32400" Type="Port" Display="always" Required="false" Mask="false">32400</Config>
</Container>
